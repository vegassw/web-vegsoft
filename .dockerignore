# Ignore node_modules
frontend/node_modules/

# Ignore Python cache
**/__pycache__/
**/*.pyc
*.pyo

# Ignore env files (will be set in Cloud Run)
**/.env

# Ignore git
.git/
.gitignore

# Ignore test files
tests/
test_reports/

# Ignore IDE
.vscode/
.idea/

# Ignore logs
*.log
/var/log/

# Ignore memory/docs
memory/
*.md
